# ─── Core ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-in-production

# ─── Database ────────────────────────────────────────────────────────────────
# Development (SQLite — default, no setup needed):
DATABASE_URL=sqlite:///instance/emergix.db

# Production (PostgreSQL):
# DATABASE_URL=postgresql://emergix:emergix@localhost:5432/emergix_db

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/
#   1. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   2. Application type: Web application
#   3. Authorised redirect URIs:
#        http://localhost:5000/auth/google/callback        (development)
#        https://yourdomain.com/auth/google/callback       (production)
#
# Leave blank to disable Google Sign-In (email/password login still works):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
